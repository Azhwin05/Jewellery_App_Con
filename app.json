{
  "expo": {
    "name": "Jewels",
    "slug": "jewelry-app",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "jewelryapp",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#5C40C9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jewels.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#5C40C9",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.jewels.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#5C40C9"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
